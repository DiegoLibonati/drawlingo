#!/bin/sh
# Pre-commit hook for Drawlingo monorepo.
# Runs lint-staged for drawlingo-api when its files are staged.
# Runs lint-staged for drawlingo-app when its files are staged.

REPO_ROOT="$(git rev-parse --show-toplevel)"
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

API_FILES=$(echo "$STAGED_FILES" | grep "^drawlingo-api/")
VUE_FILES=$(echo "$STAGED_FILES" | grep "^drawlingo-app/")

EXIT_CODE=0

if [ -n "$API_FILES" ]; then
    echo "[pre-commit] Running lint-staged for drawlingo-api..."
    if command -v npx > /dev/null; then
        (cd "$REPO_ROOT/drawlingo-api" && npx --no-install lint-staged)
    else
        echo '[pre-commit] `npx` not found. Did you install Node.js?' 1>&2
        exit 1
    fi
    EXIT_CODE=$((EXIT_CODE + $?))
fi

if [ -n "$VUE_FILES" ]; then
    echo "[pre-commit] Running lint-staged for drawlingo-app..."
    if command -v npx > /dev/null; then
        (cd "$REPO_ROOT/drawlingo-app" && npx --no-install lint-staged)
    else
        echo '[pre-commit] `npx` not found. Did you install Node.js?' 1>&2
        exit 1
    fi
    EXIT_CODE=$((EXIT_CODE + $?))
fi

exit $EXIT_CODE
