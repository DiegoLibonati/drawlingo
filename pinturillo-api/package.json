{
  "name": "pinturillo-api",
  "private": true,
  "version": "1.0.0",
  "description": "API for Pinturillo game using Express, Socket.IO, Redis and TypeScript",
  "main": "dist/server.js",
  "dependencies": {
    "express": "^4.19.2",
    "morgan": "^1.10.1",
    "redis": "^4.6.14",
    "socket.io": "^4.8.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.5",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "dev": "nodemon",
    "build": "tsc -p tsconfig.app.json && tsc-alias -p tsconfig.app.json",
    "start": "node dist/server.js",
    "test": "jest --watchAll --verbose"
  },
  "keywords": [
    "express",
    "socket.io",
    "redis",
    "typescript",
    "pinturillo"
  ],
  "author": "",
  "license": "MIT"
}
